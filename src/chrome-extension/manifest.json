{
  "manifest_version": 3,
  "name": "FieldCap Data Exporter",
  "version": "3.0.0",
  "description": "Export FieldCap job details, crew, BHA equipment, and slide/rotate metres by day to CSV via the OData API using your active logged-in session.",
  "permissions": [
    "downloads",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://fieldcap-cdn.phxtech.com/*",
    "*://*.phxtech.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.phxtech.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected-spy.js"
      ],
      "matches": [
        "*://*.phxtech.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FieldCap Exporter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
